{
  "name": "sitwallet-backend",
  "version": "1.0.0",
  "description": "Secure Node.js and MySQL backend for the SITWallet school project.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node scripts/run-sql.js sql/001_schema.sql",
